{
  "expo": {
    "name": "Good Game",
    "slug": "good-game",
    "version": "1.1.0",
    "owner": "good-game",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/icon.png",
    "splash": {
      "backgroundColor": "#0C0E14",
      "image": "./assets/brand/splash-icon.png",
      "resizeMode": "contain"
    },
    "experiments": {
      "reactCompiler": true
    },
    "android": {
      "package": "com.martinsluan.goodgame",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/icon-android-foreground.png",
        "backgroundColor": "#0C0E14"
      },
      "splash": {
        "backgroundColor": "#0C0E14",
        "image": "./assets/brand/splash-icon.png",
        "resizeMode": "contain"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0E14",
          "image": "./assets/brand/splash-icon.png",
          "dark": {
            "backgroundColor": "#0C0E14",
            "image": "./assets/brand/splash-icon.png"
          },
          "imageWidth": 220
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/brand/icon.png",
          "color": "#F18F5C",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permita que o GG use sua localização aproximada para mostrar mesas e locais próximos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o GG acesse sua biblioteca de fotos para escolher imagens de perfil e do chat da partida."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fa021ea6-92de-4e62-ae08-b64758c03259"
      }
    }
  }
}
