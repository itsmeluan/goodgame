{
  "cli": {
    "version": ">=18.5.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "environment": "preview"
    },
    "beta": {
      "autoIncrement": true,
      "environment": "production"
    },
    "production": {
      "autoIncrement": false,
      "environment": "production"
    },
    "production_111_10": {
      "distribution": "store",
      "autoIncrement": false,
      "environment": "production"
    }
  },
  "submit": {
    "beta": {
      "android": {
        "track": "internal"
      }
    },
    "production": {}
  }
}
