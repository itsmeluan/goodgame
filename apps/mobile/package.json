{
  "name": "good-game-mobile",
  "private": true,
  "main": "index.js",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:ios:dev": "npx eas-cli build --profile development --platform ios",
    "eas:build:android:dev": "npx eas-cli build --profile development --platform android",
    "eas:build:preview": "npx eas-cli build --profile preview --platform all",
    "eas:build:beta:ios": "npx eas-cli build --profile beta --platform ios",
    "eas:build:beta:android": "npx eas-cli build --profile beta --platform android",
    "eas:build:prod:ios": "npx eas-cli build --profile production --platform ios",
    "eas:build:prod:android": "npx eas-cli build --profile production --platform android",
    "eas:submit:beta:ios": "npx eas-cli submit --profile beta --platform ios",
    "eas:submit:beta:android": "npx eas-cli submit --profile beta --platform android",
    "eas:submit:prod:ios": "npx eas-cli submit --profile production --platform ios",
    "eas:submit:prod:android": "npx eas-cli submit --profile production --platform android",
    "lint": "eslint ."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.2.2",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.57.4",
    "expo": "^54.0.33",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
